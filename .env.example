# AI Employee - Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# =============================================================================
# Gmail API Configuration
# =============================================================================
# Path to your Gmail OAuth credentials JSON file
# Download from: https://console.cloud.google.com/apis/credentials
GMAIL_CREDENTIALS_PATH=./credentials/gmail_credentials.json

# Path where Gmail token will be stored (auto-generated after first auth)
GMAIL_TOKEN_PATH=./credentials/gmail_token.json

# Gmail query for filtering emails (e.g., "is:unread is:inbox" for unread inbox emails)
GMAIL_QUERY=is:unread is:inbox

# Check interval in seconds (default: 120 seconds = 2 minutes)
GMAIL_CHECK_INTERVAL=120

# =============================================================================
# LinkedIn Configuration
# =============================================================================
# LinkedIn credentials (use with caution - OAuth preferred)
# For browser automation approach:
LINKEDIN_USERNAME=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password

# Path to store LinkedIn session (avoids repeated login)
LINKEDIN_SESSION_PATH=./credentials/linkedin_session

# LinkedIn check interval in seconds (default: 300 seconds = 5 minutes)
LINKEDIN_CHECK_INTERVAL=300

# Keywords to monitor in LinkedIn messages (comma-separated)
LINKEDIN_KEYWORDS=urgent,opportunity,partnership,meeting,invoice,payment

# LinkedIn API credentials (if using official API instead of browser automation)
# LINKEDIN_CLIENT_ID=your_client_id
# LINKEDIN_CLIENT_SECRET=your_client_secret

# =============================================================================
# General Configuration
# =============================================================================
# Vault path (where Obsidian vault is located)
VAULT_PATH=./ai_employee_vault

# Development mode (set to "true" to prevent actual external actions)
DRY_RUN=false

# Maximum emails to process per check (prevents overwhelming the system)
MAX_EMAILS_PER_CHECK=50

# Maximum LinkedIn messages per check
MAX_LINKEDIN_MESSAGES_PER_CHECK=20
