# AI Employee - Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# =============================================================================
# Gmail API Configuration
# =============================================================================
# Path to your Gmail OAuth credentials JSON file
# Download from: https://console.cloud.google.com/apis/credentials
GMAIL_CREDENTIALS_PATH=./credentials/gmail_credentials.json

# Path where Gmail token will be stored (auto-generated after first auth)
GMAIL_TOKEN_PATH=./credentials/gmail_token.json

# Gmail query for filtering emails (e.g., "is:unread is:inbox" for unread inbox emails)
GMAIL_QUERY=is:unread is:inbox

# Check interval in seconds (default: 120 seconds = 2 minutes)
GMAIL_CHECK_INTERVAL=120

# =============================================================================
# LinkedIn Configuration (Official API - Recommended)
# =============================================================================
# Get these from LinkedIn Developer Portal: https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here
LINKEDIN_REDIRECT_URI=http://localhost:8000/callback

# Path to store LinkedIn API token (auto-generated after OAuth setup)
LINKEDIN_TOKEN_PATH=./credentials/linkedin_api_token.json

# LinkedIn check interval in seconds (default: 300 seconds = 5 minutes)
# NOTE: Message monitoring requires LinkedIn Partner Program access
# Posting works with standard OAuth scope (w_member_social)
LINKEDIN_CHECK_INTERVAL=300

# Content calendar interval (for scheduled posts)
CONTENT_CALENDAR_CHECK_INTERVAL=3600

# =============================================================================
# LinkedIn Legacy Configuration (Browser Automation - Deprecated)
# =============================================================================
# Only use if you don't have API access. Requires Playwright and is less reliable.
# LINKEDIN_USERNAME=your_linkedin_email@example.com
# LINKEDIN_PASSWORD=your_linkedin_password
# LINKEDIN_SESSION_PATH=./credentials/linkedin_session

# =============================================================================
# General Configuration
# =============================================================================
# Vault path (where Obsidian vault is located)
VAULT_PATH=./ai_employee_vault

# Development mode (set to "true" to prevent actual external actions)
DRY_RUN=false

# Maximum emails to process per check (prevents overwhelming the system)
MAX_EMAILS_PER_CHECK=50

# Maximum LinkedIn messages per check
MAX_LINKEDIN_MESSAGES_PER_CHECK=20

# =============================================================================
# Twitter/X Configuration
# =============================================================================
# Get these from Twitter Developer Portal: https://developer.twitter.com/en/portal/dashboard
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=

# =============================================================================
# Meta (Facebook + Instagram) Configuration
# =============================================================================
# Get these from Meta Developer Portal: https://developers.facebook.com/
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_PAGE_ID=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# =============================================================================
# Advanced Settings
# =============================================================================
# Ralph Wiggum continuous agent - max iterations before stopping
MAX_ITERATIONS=10
